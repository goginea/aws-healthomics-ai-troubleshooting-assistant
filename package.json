{
  "name": "healthomics-ai-troubleshooter",
  "version": "1.0.4",
  "description": "AI-assisted troubleshooting for AWS HealthOmics genomic workflows with custom knowledge base support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "healthomics-ai-troubleshooter": "dist/mcp-server.js"
  },
  "files": [
    "dist/**/*",
    "power/**/*",
    "cdk/**/*",
    "cdk.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:mcp": "tsc && chmod +x dist/mcp-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "aws",
    "healthomics",
    "genomics",
    "bioinformatics",
    "troubleshooting",
    "observability",
    "kiro-power"
  ],
  "author": "Avinash Gogineni",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goginea/aws-healthomics-ai-troubleshooting-assistant.git"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent": "^3.700.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.700.0",
    "@aws-sdk/client-cloudtrail": "^3.700.0",
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-eventbridge": "^3.700.0",
    "@aws-sdk/client-omics": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-xray": "^3.700.0",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^3.22.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
